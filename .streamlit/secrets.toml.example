# Copy this file to .streamlit/secrets.toml and fill in your API keys.
# Never commit secrets.toml to version control.

SARVAM_API_KEY = "your-sarvam-api-key"
GEMINI_API_KEY = "your-gemini-api-key"
TAVILY_API_KEY = "your-tavily-api-key"
FIRECRAWL_API_KEY = "your-firecrawl-api-key"

# Optional knowledge-cache configuration
KNOWLEDGE_CACHE_TTL_SECONDS = "604800"
GRAMEEN_SEVA_DB_PATH = "data/grameen_seva.sqlite3"

# Required only by the standalone Twilio server.
TWILIO_ACCOUNT_SID = "your-twilio-account-sid"
TWILIO_AUTH_TOKEN = "your-twilio-auth-token"
TWILIO_PHONE_NUMBER = "+91xxxxxxxxxx"
TWILIO_PUBLIC_BASE_URL = "https://your-twilio-server.example.com"
